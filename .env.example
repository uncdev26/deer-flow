# DeerFlow Railway — Environment Variables
# Set these in the Railway dashboard for each service

# ── Required ──────────────────────────────────────────────────────────────────
# Xiaomi MiMo API Key (get from https://platform.xiaomimimo.com)
MIMO_API_KEY=tp-you...n

# ── Optional: Additional Models ──────────────────────────────────────────────
# OPENAI_API_KEY=***
# ANTHROPIC_API_KEY=***
# ZENMUX_API_KEY=your-z...y
# DEEPSEEK_API_KEY=***
# GEMINI_API_KEY=***

# ── Optional: GitHub Integration ─────────────────────────────────────────────
# Generate at: https://github.com/settings/tokens
# Scopes: repo, workflow, read:org
GITHUB_TOKEN=ghp_yo...n

# ── Optional: Search Providers ───────────────────────────────────────────────
# SERPER_API_KEY=***       # Google Search via Serper
# TAVILY_API_KEY=***       # Tavily Search
# JINA_API_KEY=***         # Jina (used for web_fetch)

# ── Optional: LangSmith Tracing ──────────────────────────────────────────────
# LANGSMITH_TRACING=true
# LANGSMITH_API_KEY=***

# ── Railway Internal URLs (set in Railway dashboard) ─────────────────────────
# Backend service env:
#   GATEWAY_CORS_ORIGINS=https://your-frontend.up.railway.app
#
# Frontend service env:
#   NEXT_PUBLIC_BACKEND_BASE_URL=https://your-backend.up.railway.app
#   NEXT_PUBLIC_LANGGRAPH_BASE_URL=https://your-backend.up.railway.app/api
#   DEER_FLOW_INTERNAL_GATEWAY_BASE_URL=https://your-backend.up.railway.app
